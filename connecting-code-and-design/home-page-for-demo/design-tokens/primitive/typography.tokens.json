{
  "typography": {
    "font": {
      "body": { "$type": "fontFamily", "$value": "\"Helvetica Neue\", \"Avenir Next\", \"Segoe UI\", sans-serif" },
      "display": { "$type": "fontFamily", "$value": "\"Impact\", \"Arial Narrow\", \"Arial Black\", \"Avenir Next Condensed\", sans-serif" },
      "mono": { "$type": "fontFamily", "$value": "\"Fragment Mono\", \"SFMono-Regular\", \"Menlo\", \"Monaco\", \"Liberation Mono\", monospace" }
    },
    "size": {
      "small": { "$type": "fontSize", "$value": 12 },
      "body": { "$type": "fontSize", "$value": 16 },
      "cardTitle": { "$type": "fontSize", "$value": 36 },
      "hero": { "$type": "fontSize", "$value": 62 }
    },
    "weight": {
      "medium": { "$type": "fontWeight", "$value": 500 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "lineHeight": {
      "caption": { "$type": "number", "$value": 1.3 },
      "body": { "$type": "number", "$value": 1.4 },
      "display": { "$type": "number", "$value": 0.95 }
    }
  }
}
