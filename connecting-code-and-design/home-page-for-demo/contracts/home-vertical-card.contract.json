{
  "id": "home-vertical-card",
  "name": "Homepage Vertical Card",
  "tokens": {
    "color": {
      "background.primary": "surface.default",
      "text.primary": "text.primary",
      "text.secondary": "text.secondary",
      "accent.primary": "brand.500"
    },
    "spacing": {
      "padding.x.lg": "space.sm",
      "padding.y.lg": "space.sm",
      "gap.md": "space.sm"
    },
    "typography": {
      "date.size": "textSize.body",
      "title.size": "textSize.cardTitle",
      "title.weight": "weight.bold",
      "badge.size": "textSize.small"
    },
    "border": {
      "radius": "radius.lg"
    },
    "motion": {
      "transition": "motion.duration.fast"
    }
  },
  "props": {
    "variant": ["metamaterial", "atmospheric", "new-visions"],
    "size": ["default"],
    "state": ["default"]
  },
  "states": ["default"],
  "a11y": {
    "role": "button",
    "label": "Homepage vertical tour card"
  },
  "platforms": ["web", "ios"],
  "composition": {
    "slots": {
      "image": {
        "childOrder": ["image", "content"]
      },
      "content": {
        "childOrder": ["copy", "badge"]
      }
    }
  }
}
